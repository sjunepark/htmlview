{
  "name": "htmlview",
  "version": "0.1.0",
  "description": "Serve local HTML through confined loopback HTTP",
  "type": "module",
  "bin": {
    "htmlview": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "ARCHITECTURE.md",
    "PLAN.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run validate:docs && npm run build && npm run test:e2e && npm run validate:browser-origin && npm run validate:interoperability && npm run validate:package",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "tsx --test test/**/*.test.ts",
    "test:e2e": "node --test --test-concurrency=1 test-e2e/**/*.test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate:browser-origin": "npm run build --silent && playwright test --config validation/browser-origin/playwright.config.mjs",
    "validate:docs": "node validation/docs/check-links.mjs",
    "validate:interoperability": "npm run build --silent && playwright test --config validation/interoperability/playwright.config.mjs",
    "validate:agent-browser": "npm run build --silent && bash validation/interoperability/run-agent-browser.sh",
    "validate:package": "npm run build --silent && node validation/package/install-smoke.mjs",
    "validate:package:linux": "bash validation/package/run-linux.sh"
  },
  "dependencies": {
    "@toon-format/toon": "2.3.0",
    "mime-types": "3.0.2"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@eslint/js": "10.0.1",
    "@toon-format/spec": "3.3.0",
    "@types/node": "22.20.1",
    "@types/mime-types": "3.0.1",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "tsx": "4.20.6",
    "typescript-eslint": "8.64.0",
    "typescript": "6.0.3"
  }
}
