{
  "name": "htmlview",
  "version": "0.1.0",
  "description": "Serve local HTML through confined loopback HTTP",
  "type": "module",
  "bin": {
    "htmlview": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run build && npm run validate:browser-origin",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "tsx --test test/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate:browser-origin": "playwright test --config validation/browser-origin/playwright.config.mjs",
    "validate:agent-browser": "bash validation/browser-origin/run-agent-browser.sh"
  },
  "dependencies": {
    "@toon-format/toon": "2.3.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@eslint/js": "10.0.1",
    "@toon-format/spec": "3.3.0",
    "@types/node": "22.20.1",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "tsx": "4.20.6",
    "typescript-eslint": "8.64.0",
    "typescript": "6.0.3"
  }
}
