{
  "name": "@sejunpark/htmlview",
  "version": "0.1.0",
  "packageManager": "pnpm@11.13.0",
  "description": "Serve local HTML through confined loopback HTTP",
  "license": "MIT",
  "type": "module",
  "bin": {
    "htmlview": "dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/cli.js",
    "dist/generations",
    "docs/CLI.md",
    "docs/INSTALL.md",
    "docs/INTEROPERABILITY.md",
    "docs/PRODUCT.md",
    "docs/SECURITY_VALIDATION.md",
    "docs/THREAT_MODEL.md",
    "docs/decisions",
    "docs/validation",
    "README.md",
    "ARCHITECTURE.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/build.mjs",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm test && pnpm run validate:docs && pnpm run build && pnpm run validate:build && pnpm run test:e2e && pnpm run validate:browser-origin && pnpm run validate:interoperability && pnpm run validate:package",
    "example:standalone": "pnpm run build && node scripts/run-example.mjs standalone",
    "example:relative": "pnpm run build && node scripts/run-example.mjs relative",
    "example:root": "pnpm run build && node scripts/run-example.mjs root",
    "example:list": "node scripts/run-example.mjs list",
    "example:stop": "node scripts/run-example.mjs stop",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "prepack": "tsc -p tsconfig.json && node scripts/build.mjs --package",
    "test": "vitest run --config vitest.config.ts",
    "test:e2e": "node --test --test-concurrency=1 test-e2e/**/*.test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json && effect-language-service diagnostics --project tsconfig.test.json --strict",
    "validate:browser-origin": "pnpm --silent run build && playwright test --config validation/browser-origin/playwright.config.mjs",
    "validate:build": "node --test validation/build/*.test.mjs",
    "validate:docs": "node --test validation/docs/*.test.mjs && node validation/docs/check-links.mjs",
    "validate:interoperability": "pnpm --silent run build && playwright test --config validation/interoperability/playwright.config.mjs",
    "validate:browser-use": "pnpm --silent run build && bash validation/interoperability/run-browser-use.sh",
    "validate:package": "pnpm --silent run build && node validation/package/install-smoke.mjs",
    "validate:package:linux": "bash validation/package/run-linux.sh"
  },
  "dependencies": {
    "@toon-format/toon": "2.3.0",
    "mime-types": "3.0.2"
  },
  "devDependencies": {
    "@effect/language-service": "0.87.0",
    "@effect/platform-node": "4.0.0-beta.98",
    "@effect/vitest": "4.0.0-beta.98",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@toon-format/spec": "3.3.0",
    "@types/mime-types": "3.0.1",
    "@types/node": "22.20.1",
    "effect": "4.0.0-beta.98",
    "esbuild": "0.28.1",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "marked": "18.0.6",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
